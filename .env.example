# Garmin Connect credentials
GARMIN_EMAIL=your.email@example.com
GARMIN_PASSWORD=your_password_here

# Token storage directory (tokens are reused across runs; no repeated login)
GARMIN_TOKEN_PATH=~/.garmin_tokens

# SQLite database path
GARMIN_DB_PATH=garmin_sync.db

# Request delay between Garmin API calls (seconds). Be conservative.
GARMIN_REQUEST_DELAY_SECONDS=1.0

# Max retry attempts on 429 or connection errors (0 = no retry)
GARMIN_MAX_RETRIES=3

# Exponential backoff base (seconds) on retryable errors
GARMIN_BACKOFF_BASE_SECONDS=2.0

# Page size for backfill-activities (max per Garmin request)
GARMIN_BACKFILL_PAGE_SIZE=100

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
